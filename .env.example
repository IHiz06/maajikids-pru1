# =====================================================
# MaajiKids Backend v3.0 - Variables de Entorno
# =====================================================
# Copia este archivo como .env y rellena los valores

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=cambia_esta_clave_secreta_muy_larga_y_aleatoria

# --- JWT ---
JWT_SECRET_KEY=cambia_esta_clave_jwt_muy_larga_y_aleatoria
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 minutos en segundos
JWT_REFRESH_TOKEN_EXPIRES=2592000   # 30 días en segundos

# --- Supabase / PostgreSQL ---
# Opción 1: Connection string directo de Supabase (Session mode - puerto 5432)
DATABASE_URL=postgresql://postgres:[TU_PASSWORD]@db.[TU_PROJECT_REF].supabase.co:5432/postgres

# Opción 2: Transaction pooler de Supabase (puerto 6543)
# DATABASE_URL=postgresql://postgres.[TU_PROJECT_REF]:[TU_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- Fernet AES-256 (datos médicos) ---
# Genera una clave con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=genera_tu_clave_fernet_aqui

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret


# --- MercadoPago ---
MP_ACCESS_TOKEN=tu_mp_access_token
MP_WEBHOOK_SECRET=tu_mp_webhook_secret
MP_SUCCESS_URL=https://tu-dominio.com/pagos/exito
MP_FAILURE_URL=https://tu-dominio.com/pagos/fallo
MP_PENDING_URL=https://tu-dominio.com/pagos/pendiente

# --- Gemini AI ---
GEMINI_API_KEY=tu_gemini_api_key

# --- CORS ---
FRONTEND_URL=http://localhost:3000

# --- Rate Limiting ---
RATELIMIT_DEFAULT=100 per minute
